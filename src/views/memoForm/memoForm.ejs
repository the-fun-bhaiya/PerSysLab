<!DOCTYPE html>
<html lang="hi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>किड्स प्रीमियम फॉर्म</title>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>

    <style>
        :root {
            --bg1: #0f172a;
            --bg2: #111827;
            --card: rgba(255, 255, 255, .10);
            --card2: rgba(255, 255, 255, .16);
            --stroke: rgba(255, 255, 255, .18);
            --text: #f8fafc;
            --muted: rgba(248, 250, 252, .72);
            --primary: #a78bfa;
            --secondary: #22d3ee;
            --accent: #fb7185;
            --gold: #fbbf24;
            --shadow: 0 24px 80px rgba(0, 0, 0, .35);
            --radius: 30px;
        }

        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent
        }

        html,
        body {
            margin: 0;
            padding: 0;
            width: 100%;
            min-height: 100%;
            font-family: "Segoe UI", "Noto Sans Devanagari", system-ui, sans-serif;
            overflow-x: hidden;
            background: #070b14;
            color: var(--text)
        }

        body {
            min-height: 100vh;
            position: relative;
            background:
                radial-gradient(circle at top left, rgba(167, 139, 250, .24), transparent 28%),
                radial-gradient(circle at top right, rgba(34, 211, 238, .18), transparent 25%),
                radial-gradient(circle at bottom left, rgba(251, 113, 133, .16), transparent 24%),
                linear-gradient(180deg, var(--bg1), var(--bg2));
        }

        .aurora {
            position: fixed;
            inset: -20%;
            pointer-events: none;
            background:
                radial-gradient(circle at 20% 20%, rgba(167, 139, 250, .18), transparent 18%),
                radial-gradient(circle at 80% 30%, rgba(34, 211, 238, .14), transparent 20%),
                radial-gradient(circle at 60% 80%, rgba(251, 191, 36, .12), transparent 18%),
                radial-gradient(circle at 30% 70%, rgba(251, 113, 133, .12), transparent 16%);
            filter: blur(20px);
            animation: drift 14s ease-in-out infinite alternate;
            z-index: 0;
        }

        .blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(18px);
            opacity: .24;
            pointer-events: none;
            animation: floaty 9s ease-in-out infinite;
            z-index: 0;
        }

        .blob.one {
            width: 160px;
            height: 160px;
            background: #a78bfa;
            top: -30px;
            left: -50px
        }

        .blob.two {
            width: 110px;
            height: 110px;
            background: #22d3ee;
            top: 120px;
            right: -25px;
            animation-delay: 1.3s
        }

        .blob.three {
            width: 140px;
            height: 140px;
            background: #fb7185;
            bottom: 50px;
            left: 18px;
            animation-delay: 2.4s
        }

        .blob.four {
            width: 100px;
            height: 100px;
            background: #fbbf24;
            bottom: 110px;
            right: 24px;
            animation-delay: 3.2s
        }

        .wrap {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        .card {
            width: 100%;
            max-width: 430px;
            background: linear-gradient(180deg, rgba(255, 255, 255, .12), rgba(255, 255, 255, .08));
            border: 1px solid var(--stroke);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            overflow: hidden;
            position: relative;
            padding: 18px;
            transform: translateY(0);
            animation: popIn .8s cubic-bezier(.2, .9, .2, 1);
        }

        .card::before {
            content: "";
            position: absolute;
            inset: -2px;
            background: linear-gradient(135deg, rgba(167, 139, 250, .35), rgba(34, 211, 238, .20), rgba(251, 113, 133, .22), rgba(251, 191, 36, .18));
            opacity: .24;
            pointer-events: none;
        }

        .inner {
            position: relative;
            z-index: 1;
        }

        .topline {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 14px;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 14px;
            border-radius: 999px;
            background: linear-gradient(135deg, rgba(167, 139, 250, .28), rgba(34, 211, 238, .20));
            border: 1px solid rgba(255, 255, 255, .16);
            color: var(--text);
            font-weight: 800;
            font-size: 13px;
            box-shadow: 0 10px 26px rgba(0, 0, 0, .18);
        }

        .mini-pill {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            background: rgba(255, 255, 255, .10);
            border: 1px solid rgba(255, 255, 255, .16);
            font-size: 20px;
            animation: bounce 1.8s ease-in-out infinite;
        }

        .hero {
            display: grid;
            grid-template-columns: 88px 1fr;
            gap: 14px;
            align-items: center;
            margin: 10px 0 8px;
        }

        .mascot {
            width: 88px;
            height: 88px;
            border-radius: 26px;
            background:
                radial-gradient(circle at 35% 30%, #fff 0 8px, transparent 9px),
                radial-gradient(circle at 65% 30%, #fff 0 8px, transparent 9px),
                radial-gradient(circle at 50% 62%, #ff8fab 0 10px, transparent 11px),
                linear-gradient(135deg, rgba(167, 139, 250, .92), rgba(34, 211, 238, .92));
            box-shadow: 0 18px 40px rgba(0, 0, 0, .22);
            position: relative;
            transform-origin: center;
            animation: wobble 2.8s ease-in-out infinite;
        }

        .mascot::before {
            content: "";
            position: absolute;
            inset: 12px 15px 18px;
            border-radius: 22px;
            background: rgba(255, 255, 255, .18);
            transform: rotate(-7deg);
        }

        .mascot::after {
            content: "";
            position: absolute;
            width: 22px;
            height: 10px;
            left: 50%;
            bottom: 16px;
            transform: translateX(-50%);
            border-radius: 999px;
            background: rgba(255, 255, 255, .82);
            box-shadow: -18px -10px 0 0 rgba(255, 255, 255, .0), 18px -10px 0 0 rgba(255, 255, 255, .0);
        }

        h1 {
            margin: 0;
            font-size: 28px;
            line-height: 1.06;
            letter-spacing: -.03em;
        }

        .subtitle {
            margin: 10px 0 0;
            color: var(--muted);
            font-size: 15px;
            line-height: 1.6;
        }

        .spark-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 14px 2px 10px;
            user-select: none;
        }

        .spark-row span {
            font-size: 24px;
            animation: bounce 1.6s ease-in-out infinite;
            filter: drop-shadow(0 8px 20px rgba(0, 0, 0, .25));
        }

        .spark-row span:nth-child(2) {
            animation-delay: .15s
        }

        .spark-row span:nth-child(3) {
            animation-delay: .3s
        }

        .spark-row span:nth-child(4) {
            animation-delay: .45s
        }

        .form-box {
            display: none;
            margin-top: 12px;
            animation: fadeUp .55s ease-out;
        }

        label {
            display: block;
            margin-bottom: 10px;
            font-size: 15px;
            font-weight: 800;
            color: var(--text);
        }

        .input-wrap {
            position: relative;
        }

        input[type="password"],
        input[type="text"] {
            width: 100%;
            border: none;
            outline: none;
            border-radius: 20px;
            padding: 16px 16px 16px 16px;
            font-size: 16px;
            color: #0f172a;
            background: rgba(255, 255, 255, .94);
            box-shadow:
                inset 0 1px 0 rgba(255, 255, 255, .8),
                0 14px 30px rgba(0, 0, 0, .12);
            transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
        }

        input:focus {
            transform: translateY(-1px);
            box-shadow:
                0 0 0 4px rgba(167, 139, 250, .20),
                0 16px 36px rgba(0, 0, 0, .16);
        }

        .btn {
            width: 100%;
            margin-top: 16px;
            border: none;
            border-radius: 20px;
            padding: 15px 16px;
            font-size: 16px;
            font-weight: 900;
            color: white;
            cursor: pointer;
            background: linear-gradient(135deg, #a78bfa, #22d3ee 55%, #fb7185);
            box-shadow: 0 16px 34px rgba(0, 0, 0, .22);
            transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
            position: relative;
            overflow: hidden;
        }

        .btn::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent 20%, rgba(255, 255, 255, .26), transparent 60%);
            transform: translateX(-120%);
            animation: shine 3.5s ease-in-out infinite;
        }

        .btn:active {
            transform: scale(.98)
        }

        .btn:hover {
            filter: saturate(1.1)
        }

        .note {
            margin-top: 12px;
            color: var(--muted);
            font-size: 13px;
            line-height: 1.5;
            text-align: center;
        }

        .chip-row {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-top: 12px;
        }

        .chip {
            padding: 8px 12px;
            border-radius: 999px;
            background: rgba(255, 255, 255, .08);
            border: 1px solid rgba(255, 255, 255, .12);
            font-size: 12px;
            color: rgba(255, 255, 255, .86);
        }

        @keyframes popIn {
            from {
                opacity: 0;
                transform: translateY(18px) scale(.97)
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1)
            }
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(10px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        @keyframes drift {
            from {
                transform: translate3d(-1%, -1%, 0) scale(1)
            }

            to {
                transform: translate3d(1.5%, 1.5%, 0) scale(1.05)
            }
        }

        @keyframes floaty {

            0%,
            100% {
                transform: translateY(0) scale(1)
            }

            50% {
                transform: translateY(16px) scale(1.08)
            }
        }

        @keyframes bounce {

            0%,
            100% {
                transform: translateY(0)
            }

            50% {
                transform: translateY(-8px)
            }
        }

        @keyframes wobble {

            0%,
            100% {
                transform: rotate(0deg) translateY(0)
            }

            25% {
                transform: rotate(-2deg) translateY(-2px)
            }

            50% {
                transform: rotate(2deg) translateY(0)
            }

            75% {
                transform: rotate(-1deg) translateY(-1px)
            }
        }

        @keyframes shine {

            0%,
            55% {
                transform: translateX(-120%)
            }

            100% {
                transform: translateX(120%)
            }
        }

        @media (max-width: 380px) {
            .hero {
                grid-template-columns: 74px 1fr
            }

            .mascot {
                width: 74px;
                height: 74px;
                border-radius: 22px
            }

            h1 {
                font-size: 24px
            }

            .card {
                padding: 16px
            }
        }

        @media (min-width: 768px) {
            .card {
                max-width: 460px;
                padding: 22px
            }

            h1 {
                font-size: 32px
            }

            .subtitle {
                font-size: 16px
            }
        }
    </style>
</head>

<body>
    <div class="aurora"></div>
    <div class="blob one"></div>
    <div class="blob two"></div>
    <div class="blob three"></div>
    <div class="blob four"></div>

    <div class="wrap">
        <div class="card">
            <div class="inner">
                <div class="topline">
                    <div class="badge">✨ प्रीमियम किड्स ज़ोन ✨</div>
                    <div class="mini-pill">🎈</div>
                </div>

                <div class="hero">
                    <div class="mascot" aria-hidden="true"></div>
                    <div>
                        <h1>हाय दोस्त! 👋</h1>
                        <p class="subtitle">
                            पहले एक छोटा-सा मस्ती वाला सवाल आएगा। सही जवाब पर ही अगला मज़ेदार स्टेप खुलेगा। 😄
                        </p>
                    </div>
                </div>

                <div class="spark-row" aria-hidden="true">
                    <span>🌟</span>
                    <span>🫧</span>
                    <span>🍭</span>
                    <span>✨</span>
                </div>

                <div class="form-box" id="formBox">
                    <form action="/memories" method="POST">
                        <div class="input-wrap">
                            <label for="password">5th class se ho to password batao 🔐</label>
                            <input type="password" id="password" name="password" placeholder="पासवर्ड यहाँ लिखो..."
                                autocomplete="off" required />
                        </div>

                        <button type="submit" class="btn">अंदर जाओ 🚀</button>
                    </form>

                    <div class="chip-row">
                        <span class="chip">मोबाइल फर्स्ट 📱</span>
                        <span class="chip">क्यूट एनीमेशन ✨</span>
                        <span class="chip">फन वाइब 🎉</span>
                    </div>

                    <div class="note">यहाँ सब कुछ playful रखा गया है ताकि form boring न लगे 😺</div>
                </div>
            </div>
        </div>
    </div>

    <% if (typeof error !=="undefined" ) { %>
        <script>
        Swal.fire({
        title: "गलत पासवर्ड 😵",
        text: "अरे! सही वाला डालो ना 😄",
        icon: "error",
        confirmButtonText: "फिर से कोशिश करो",
        confirmButtonColor: "#fb7185"
        });
        </script>
    <% } %>
    <script>
        const audioCtx = window.AudioContext ? new (window.AudioContext || window.webkitAudioContext)() : null;
        
        function beepSequence(pattern) {
            if (!audioCtx) return;

            if (audioCtx.state === "suspended") {
                audioCtx.resume().catch(() => { });
            }

            let start = audioCtx.currentTime + 0.02;

            pattern.forEach(({ freq, duration, gain }, index) => {
                const osc = audioCtx.createOscillator();
                const amp = audioCtx.createGain();

                osc.type = "sine";
                osc.frequency.setValueAtTime(freq, start + index * 0.08);

                amp.gain.setValueAtTime(0.0001, start + index * 0.08);
                amp.gain.exponentialRampToValueAtTime(gain, start + index * 0.08 + 0.02);
                amp.gain.exponentialRampToValueAtTime(0.0001, start + index * 0.08 + duration);

                osc.connect(amp);
                amp.connect(audioCtx.destination);

                osc.start(start + index * 0.08);
                osc.stop(start + index * 0.08 + duration + 0.03);
            });
        }

        function playYesSound() {
            beepSequence([
                { freq: 523.25, duration: 0.12, gain: 0.08 },
                { freq: 659.25, duration: 0.12, gain: 0.09 },
                { freq: 783.99, duration: 0.16, gain: 0.1 },
                { freq: 1046.5, duration: 0.18, gain: 0.09 }
            ]);
        }

        function playNoSound() {
            beepSequence([
                { freq: 392, duration: 0.16, gain: 0.08 },
                { freq: 349.23, duration: 0.18, gain: 0.08 },
                { freq: 293.66, duration: 0.24, gain: 0.08 }
            ]);
        }

        function celebrate() {
            confetti({
                particleCount: 120,
                spread: 80,
                origin: { y: 0.68 }
            });

            setTimeout(() => {
                confetti({
                    particleCount: 70,
                    spread: 110,
                    origin: { y: 0.64 }
                });
            }, 180);
        }

        window.addEventListener("load", function () {
            Swal.fire({
                title: "हम्म... आ गए क्या आप? 🤔",
                html: "बताया था कन्हा भैया ने आपके बारे में, 5th class में हो ना?",
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "हाँ ✅",
                cancelButtonText: "ना ❌",
                confirmButtonColor: "#8b5cf6",
                cancelButtonColor: "#fb7185",
                background: "rgba(15, 23, 42, .96)",
                color: "#f8fafc",
                customClass: {
                    popup: "swal2-border-radius"
                },
                allowOutsideClick: false,
                allowEscapeKey: false
            }).then((result) => {
                if (result.isConfirmed) {
                    playYesSound();
                    celebrate();

                    const box = document.getElementById("formBox");
                    box.style.display = "block";
                    setTimeout(() => {
                        document.getElementById("password").focus();
                    }, 220);

                    Swal.fire({
                        title: "याय! 🎉",
                        text: "अब पासवर्ड डालो और आगे बढ़ो!",
                        icon: "success",
                        confirmButtonText: "ठीक है",
                        confirmButtonColor: "#22c55e",
                        background: "rgba(15, 23, 42, .96)",
                        color: "#f8fafc"
                    });
                } else {
                    playNoSound();
                    Swal.fire({
                        title: "ओह्ह 😅",
                        text: "कोई बात नहीं, यह वाला खेल 5th class दोस्तों के लिए रखा गया है।",
                        icon: "info",
                        confirmButtonText: "ठीक है",
                        confirmButtonColor: "#8b5cf6",
                        background: "rgba(15, 23, 42, .96)",
                        color: "#f8fafc"
                    });
                }
            });
        });
    </script>
</body>

</html>
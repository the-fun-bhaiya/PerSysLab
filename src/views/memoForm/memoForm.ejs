<!DOCTYPE html>
<html lang="hi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>यादों का पिटारा</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-color: #ff6b6b;
            --secondary-color: #4ecdc4;
            --bg-color: #f7fff7;
            --text-dark: #2c3e50;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .magic-btn {
            background-color: var(--primary-color);
            color: white;
            font-size: 1.5rem;
            padding: 15px 40px;
            border-radius: 50px;
            border: none;
            box-shadow: 0 10px 20px rgba(255, 107, 107, 0.3);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .magic-btn:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 25px rgba(255, 107, 107, 0.5);
            background-color: #ff5252;
            color: white;
        }

        .swal2-popup {
            border-radius: 20px !important;
        }
    </style>
</head>

<body>

    <div class="text-center animate__animated animate__zoomIn">
        <h1 class="mb-4" style="color: var(--text-dark); font-weight: 800;">हमारी यादें ✨</h1>
        <button class="magic-btn" onclick="startMagic()">पिटारा खोलें</button>
    </div>

    <script>
        async function startMagic() {
            // Step 1: Ask for Class
            const { value: studentClass } = await Swal.fire({
                title: 'आप कौनसी क्लास में हैं?',
                input: 'radio',
                inputOptions: {
                    '5': '5th क्लास',
                    '7': '7th क्लास'
                },
                inputValidator: (value) => {
                    if (!value) return 'अरे! क्लास तो सेलेक्ट करो!'
                },
                confirmButtonText: 'आगे बढ़ें &rarr;',
                confirmButtonColor: '#4ecdc4'
            });

            if (studentClass) {
                console.log(studentClass)
                // Step 2: Dynamic Text based on Class
                let questionTitle = studentClass === '5' ? 'पासवर्ड क्या है?' : 'हम अभी कौनसी किताब पढ़ रहे हैं?';
                let inputPlaceholder = studentClass === '5' ? 'सीक्रेट पासवर्ड यहाँ लिखें...' : 'किताब का नाम...';

                const { value: answer } = await Swal.fire({
                    title: questionTitle,
                    input: 'text',
                    inputPlaceholder: inputPlaceholder,
                    showCancelButton: true,
                    confirmButtonText: 'खोलें 🚀',
                    cancelButtonText: 'रद्द करें',
                    inputValidator: (value) => {
                        if (!value) return 'kitab ka naam to dalo!?'
                    },
                    confirmButtonColor: '#ff6b6b'
                });

                if (answer) {
                    console.log(answer)
                    // Step 3: Send request to /memories (Backend should expect POST and return JSON)
                    try {
                        console.log("haan")
                        const response = await fetch('/memories/', { // Use a specific auth route or modify as per your backend
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ password: answer.toLowerCase() })
                        });

                        const result = await response.json();
                        console.dir(result);
                        if (result.success) {
                            console.log("hmmm suc")
                            window.location.href = '/memories/auth';
                        } else {
                            console.log("hm er")
                            // Playful Error Handling
                            let hintMsg = studentClass === '5'
                                ? 'गड़बड़ हो गई! हिंट: सभी छोटे अक्षर टाइप करो और लगातार लिखो बिना स्पेस के।'
                                : 'अरे नहीं! हिंट: किताब का नाम याद नहीं आ रहा तो potter magical character के बारे में सर्च करो।';

                            Swal.fire({
                                icon: 'error',
                                title: 'ऊप्स! गलत जवाब 🙈',
                                text: hintMsg,
                                confirmButtonColor: '#ff6b6b'
                            });
                        }
                    } catch (error) {
                        console.error("Error connecting to server:", error);
                    }
                }
            }
        }
    </script>
</body>

</html>
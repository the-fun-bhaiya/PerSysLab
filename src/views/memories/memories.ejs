<!DOCTYPE html>
<html lang="hi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>सुनहरी यादें</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        :root {
            --bg-color: #f0f7f4;
            --card-bg: #ffffff;
            --accent: #ff9f1c;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding-bottom: 50px;
        }

        /* Gallery Grid */
        .gallery-container {
            column-count: 3;
            column-gap: 15px;
            padding: 20px;
        }

        .gallery-item {
            break-inside: avoid;
            margin-bottom: 15px;
            border-radius: 15px;
            overflow: hidden;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            transition: transform 0.2s ease;
        }

        .gallery-item:hover {
            transform: scale(1.02);
        }

        .gallery-item img {
            width: 100%;
            display: block;
        }

        /* Lightbox CSS */
        #lightbox {
            display: none;
            position: fixed;
            z-index: 999;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            align-items: center;
            justify-content: center;
            flex-direction: column;
        }

        #lightbox img {
            max-width: 90%;
            max-height: 80%;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.2);
        }

        #close-btn {
            color: white;
            font-size: 40px;
            position: absolute;
            top: 20px;
            right: 40px;
            cursor: pointer;
        }

        /* Survey Section */
        .survey-card {
            background: var(--card-bg);
            border-radius: 20px;
            border: none;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            padding: 30px;
            margin-top: 40px;
        }

        .form-label {
            font-weight: 600;
            color: #333;
            font-size: 1.1rem;
        }

        .form-check-input:checked {
            background-color: var(--accent);
            border-color: var(--accent);
        }

        .submit-btn {
            background-color: var(--accent);
            color: white;
            border-radius: 30px;
            padding: 10px 30px;
            font-weight: bold;
            border: none;
        }

        .submit-btn:hover {
            background-color: #e88d14;
        }

        @media (max-width: 768px) {
            .gallery-container {
                column-count: 2;
            }
        }

        @media (max-width: 480px) {
            .gallery-container {
                column-count: 1;
            }
        }
    </style>
</head>

<body>

    <div class="container mt-5 animate__animated animate__fadeIn">
        <h2 class="text-center mb-4" style="color: #2c3e50; font-weight: 800;">📸 हमारी शानदार यादें</h2>

        <div class="gallery-container">
            <% if(images && images.length> 0) { %>
                <% images.forEach(function(imgSrc) { %>
                    <div class="gallery-item" onclick="openLightbox('<%= imgSrc %>')">
                        <img src="<%= imgSrc %>" alt="Memory">
                    </div>
                    <% }); %>
                        <% } else { %>
                            <p class="text-center w-100">अभी कोई यादें नहीं हैं!</p>
                            <% } %>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card survey-card animate__animated animate__fadeInUp">
                    <h3 class="text-center mb-4">🤔 आपका क्या ख्याल है?</h3>
        
                    <form action="/survey" method="POST">
        
                        <div class="mb-5">
                            <label class="form-label mb-3"> क्या मुझे प्रोजेक्टर खरीदना चाहिए जिससे अपन स्मार्ट पढ़ाई कर
                                सकें?</label>
        
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="projector_vote" id="proj_yes" value="yes"
                                    required>
                                <label class="form-check-label" for="proj_yes">हाँ! ये कोई पूछने की बात है क्या.</label>
                            </div>
                            <div class="progress mb-3" style="height: 10px; background-color: #e9ecef;">
                                <div class="progress-bar bg-success animate__animated animate__slideInLeft" role="progressbar"
                                    style="width: <%= (voteData.projector.yes / (voteData.projector.yes + voteData.projector.no + voteData.projector.maybe) * 100).toFixed(0) %>%"
                                    aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <small class="text-muted d-block mt-n2 mb-3">कुल वोट: <%= voteData.projector.yes %></small>
        
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="projector_vote" id="proj_no" value="no">
                                <label class="form-check-label" for="proj_no">नाह, मुझे नि पसंद</label>
                            </div>
                            <div class="progress mb-3" style="height: 10px;">
                                <div class="progress-bar bg-danger"
                                    style="width: <%= (voteData.projector.no / (voteData.projector.yes + voteData.projector.no + voteData.projector.maybe) * 100).toFixed(0) %>%">
                                </div>
                            </div>
                            <small class="text-muted d-block mb-3">कुल वोट: <%= voteData.projector.no %></small>
        
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="projector_vote" id="proj_dk"
                                    value="dont_know">
                                <label class="form-check-label" for="proj_dk">पता नहीं</label>
                            </div>
                            <div class="progress mb-3" style="height: 10px;">
                                <div class="progress-bar bg-secondary"
                                    style="width: <%= (voteData.projector.maybe / (voteData.projector.yes + voteData.projector.no + voteData.projector.maybe) * 100).toFixed(0) %>%">
                                </div>
                            </div>
                            <small class="text-muted d-block mb-3">कुल वोट: <%= voteData.projector.maybe %></small>
                        </div>
        
                        <hr class="my-5" style="border-top: 2px dashed #ccc;">
        
                        <div class="mb-5">
                            <label class="form-label mb-3">२. वो जो बज़र पिछली साल मंगवाए थे, उनसे अपन एक क्विज़ कम्पटीशन करें
                                क्या?</label>
        
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="buzzer_vote" id="buz_yes" value="yes"
                                    required>
                                <label class="form-check-label" for="buz_yes">हाँ! ये कोई पूछने की बात है क्या.</label>
                            </div>
                            <div class="progress mb-3" style="height: 10px;">
                                <div class="progress-bar bg-success"
                                    style="width: <%= (voteData.buzzer.yes / (voteData.buzzer.yes + voteData.buzzer.no + voteData.buzzer.maybe) * 100).toFixed(0) %>%">
                                </div>
                            </div>
                            <small class="text-muted d-block mb-3">कुल वोट: <%= voteData.buzzer.yes %></small>
        
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="buzzer_vote" id="buz_no" value="no">
                                <label class="form-check-label" for="buz_no">नाह, मुझे नि पसंद</label>
                            </div>
                            <div class="progress mb-3" style="height: 10px;">
                                <div class="progress-bar bg-danger"
                                    style="width: <%= (voteData.buzzer.no / (voteData.buzzer.yes + voteData.buzzer.no + voteData.buzzer.maybe) * 100).toFixed(0) %>%">
                                </div>
                            </div>
                            <small class="text-muted d-block mb-3">कुल वोट: <%= voteData.buzzer.no %></small>
        
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="buzzer_vote" id="buz_dk" value="dont_know">
                                <label class="form-check-label" for="buz_dk">पता नहीं</label>
                            </div>
                            <div class="progress mb-3" style="height: 10px;">
                                <div class="progress-bar bg-secondary"
                                    style="width: <%= (voteData.buzzer.maybe / (voteData.buzzer.yes + voteData.buzzer.no + voteData.buzzer.maybe) * 100).toFixed(0) %>%">
                                </div>
                            </div>
                            <small class="text-muted d-block mb-3">कुल वोट: <%= voteData.buzzer.maybe %></small>
                        </div>
        
                        <div class="mb-4">
                            <label for="directMsg" class="form-label">३. क्या आप कुछ कहना चाहेंगे या बताना चाहेंगे? कुछ भी कह
                                सकते हैं, ज्यादा सोचने की जरूरत नहीं है और चिंता मत करें आपका नाम नहीं आएगा, पर उल्टा-सीधा कुछ
                                नहीं लिखना है:</label>
                            <textarea class="form-control shadow-sm" id="directMsg" name="direct_message" rows="4"
                                placeholder="यहाँ लिखें..." style="border-radius: 15px;"></textarea>
                        </div>
        
                        <div class="text-center">
                            <button type="submit" class="submit-btn w-50 shadow-lg">वोट और मैसेज भेजें 🚀</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    <div id="lightbox">
        <span id="close-btn" onclick="closeLightbox()">&times;</span>
        <img id="lightbox-img" src="" alt="Full View">
    </div>

    <script>
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');

        function openLightbox(src) {
            lightboxImg.src = src;
            lightbox.style.display = 'flex';
            // Simple fade in effect
            lightbox.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 300, fill: 'forwards' });
        }

        function closeLightbox() {
            lightbox.style.display = 'none';
            lightboxImg.src = '';
        }

        // Close lightbox if clicked outside the image
        lightbox.addEventListener('click', function (e) {
            if (e.target === lightbox) {
                closeLightbox();
            }
        });
    </script>

</body>

</html>
<!DOCTYPE html>
<html lang="hi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>मस्ती गैलरी 🎈</title>

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: "Segoe UI", "Noto Sans Devanagari", sans-serif;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            color: white;
            padding: 14px;
        }

        h1 {
            text-align: center;
            margin: 10px 0 18px;
            font-size: 26px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        @media(min-width:600px) {
            .grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .card {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 18px;
            overflow: hidden;
            cursor: pointer;
            transition: .25s;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .card:active {
            transform: scale(0.96);
        }

        .card img {
            width: 100%;
            height: 140px;
            object-fit: cover;
        }

        .text {
            padding: 10px;
            font-size: 14px;
            text-align: center;
        }

        /* fullscreen viewer */
        .viewer {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.9);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 999;
            animation: fade .3s ease;
        }

        .viewer img {
            max-width: 95%;
            max-height: 85%;
            border-radius: 14px;
        }

        .close {
            position: absolute;
            top: 18px;
            right: 18px;
            font-size: 28px;
            cursor: pointer;
        }

        @keyframes fade {
            from {
                opacity: 0
            }

            to {
                opacity: 1
            }
        }
    </style>
</head>

<body>

    <h1>मस्ती वाली गैलरी 🎉</h1>

    <div class="grid">
        <% const funnyTexts=[ "ये फोटो तो swag में है 😎" , "कौन है ये superstar ⭐", "इतनी खुशी क्यों भाई 🤣" ]; %>

            <% images.forEach((img, i)=> { %>
                <div class="card" onclick="openViewer('<%= img %>')">
                    <img src="<%= img %>" />
                    <div class="text">
                        <%= funnyTexts[Math.floor(Math.random() * funnyTexts.length)] %>
                    </div>
                </div>
                <% }) %>
    </div>

    <div class="viewer" id="viewer">
        <span class="close" onclick="closeViewer()">✖</span>
        <img id="viewerImg" src="" />
    </div>

    <script>
        function openViewer(src) {
            const viewer = document.getElementById("viewer");
            const img = document.getElementById("viewerImg");

            img.src = src;
            viewer.style.display = "flex";
        }

        function closeViewer() {
            document.getElementById("viewer").style.display = "none";
        }
    </script>

</body>

</html>
<% layout("layout/boilerplate") -%>
  <%  
    let heading; 
    let endpoint; 
    if (typeof login == "undefined") {
      heading = "Create Account";
      endpoint = "register"
    } else {
      heading = "Login To Your Lab";
      endpoint = "login"
    }
  %>
<div class="auth-container">
  
  <div class="w-100" style="max-width: 420px;">
    
    <div class="auth-brand">
      <i class="fas fa-leaf text-success"></i>
      <h2 class="fw-bold mb-0">PerSysLab</h2>
      <p class="text-muted small">Initialize Your Personal Lab System</p>
    </div>

    <div class="psl-card shadow-lg">
      <h3 class="h5 fw-bold mb-4"><%= heading %></h3>

      <form id="form" class="needs-validation" novalidate>

        <div class="mb-4">
          <label for="username" class="form-label small fw-bold text-uppercase">Username</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-user"></i></span>
            <input 
              type="text" 
              id="username"
              class="form-control psl-input psl-input-with-icon" 
              name="username"
              maxlength="20"
              placeholder="e.g. lab_explorer"
              required
            >
            <div class="invalid-feedback">
              Username is required (max 20 characters).
            </div>
          </div>
          <div class="form-text x-small mt-1">
            Visible across your system lab logs.
          </div>
        </div>

        <div class="mb-4">
          <label for="password" class="form-label small fw-bold text-uppercase">Password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-lock"></i></span>
            <input 
              type="password"
              id="password" 
              class="form-control psl-input psl-input-with-icon" 
              name="password"
              placeholder="*******"
              required
            >
            <span class="input-group-text password-toggle" id="eye">
              <i class="fas fa-eye" id="toggleIcon"></i>
            </span>
            <div class="invalid-feedback">
              Password is required.
            </div>
          </div>
        </div>

        <button type="button" data-endpoint="/user/<%= endpoint %>" id="submitBtn" class="psl-btn psl-btn-primary w-100 mb-3 py-2 fw-bold">
          <i class="fas fa-rocket me-2"></i> Initialize Lab
        </button>
        <% if (typeof login == "undefined") { %>
          <div class="text-center mt-3">
            <p class="text-muted small mb-0">
              Already have a system? 
              <a href="/user/login" class="psl-link fw-bold">Login here</a>
            </p>
          </div>
        <% } %>
      </form>
    </div>

    <p class="text-center text-muted mt-4 x-small" style="font-size: 0.75rem;">
      &copy; <%= new Date().getFullYear() %> PerSysLab Core v1.0.0
    </p>

  </div>
</div>
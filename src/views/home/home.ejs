<% layout("layout/boilerplate") -%>
<main>

  <div class="psl-hero-wrapper">
  <nav class="psl-navbar sticky-top">
    <div class="container d-flex align-items-center justify-content-between">
      <a href="/" class="d-flex align-items-center gap-2 text-white text-decoration-none fw-bold fs-4">
        <i class="fas fa-leaf text-success"></i>
        <span>PerSysLab</span>
      </a>

      <div class="d-none d-md-flex align-items-center gap-4">
        <a href="#features" class="text-white-50 text-decoration-none">Features</a>
        <a href="#progress" class="text-white-50 text-decoration-none">Progress</a>
        <a href="#community" class="text-white-50 text-decoration-none">Community</a>
      </div>

      <div class="d-flex align-items-center gap-2">
        <a href="/user/login" class="psl-btn">Log In</a>
        <a href="/user/register" class="psl-btn psl-btn-accent">Start Free</a>
      </div>
    </div>
  </nav>

  <header class="psl-home-hero text-white">
    <div class="container py-5">
      <div class="row align-items-center g-5">
        <div class="col-lg-6">
          <span class="psl-mood psl-mood-creative mb-3 d-inline-flex align-items-center gap-2">
            <i class="fas fa-sparkles"></i>
            Your calm place for daily tracking
          </span>

          <h1 class="display-4 fw-bold mt-3 mb-3">
            Track your mood, your wins, and your growth — one gentle day at a time.
          </h1>

          <p class="lead text-white-50 mb-4">
            PerSysLab helps you notice patterns, celebrate progress, and stay connected to yourself without pressure.
            It feels simple, friendly, and made for real life.
          </p>

          <div class="d-flex flex-wrap gap-3">
            <a href="/user/register" class="psl-btn psl-btn-success psl-btn-lg">
              Get Started Free
            </a>
            <a href="#features" class="psl-glass-btn">
              See How It Works
            </a>
          </div>

          <div class="row g-3 mt-4">
            <div class="col-sm-4">
              <div class="psl-home-metric">
                <div class="fw-bold fs-5">Mood</div>
                <small class="text-white-50">Daily check-ins</small>
              </div>
            </div>
            <div class="col-sm-4">
              <div class="psl-home-metric">
                <div class="fw-bold fs-5">Progress</div>
                <small class="text-white-50">Habits & goals</small>
              </div>
            </div>
            <div class="col-sm-4">
              <div class="psl-home-metric">
                <div class="fw-bold fs-5">Insights</div>
                <small class="text-white-50">Helpful trends</small>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="psl-home-showcase">
            <div class="psl-home-device psl-glass-card">
              <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&q=80&w=1200"
                alt="People collaborating and discussing progress" class="psl-home-device-img">

              <div class="p-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                  <div>
                    <h5 class="mb-0 text-dark">Today’s Snapshot</h5>
                    <small class="text-muted">A quick look at your day</small>
                  </div>
                  <span class="psl-mood psl-mood-happy">Good</span>
                </div>

                <div class="psl-home-mini-grid">
                  <div class="psl-home-mini-card">
                    <small class="text-body">Focus</small>
                    <div class="fw-bold text-dark">8.4 / 10</div>
                  </div>
                  <div class="psl-home-mini-card">
                    <small class="text-body">Mood</small>
                    <div class="fw-bold text-dark">Calm</div>
                  </div>
                  <div class="psl-home-mini-card">
                    <small class="text-body">Wins</small>
                    <div class="fw-bold text-dark">5 logged</div>
                  </div>
                </div>

                <div class="mt-4">
                  <div class="d-flex justify-content-between mb-2">
                    <small class="text-muted">Weekly balance</small>
                    <small class="text-muted">78%</small>
                  </div>
                  <div class="progress psl-home-progress">
                    <div class="progress-bar" style="width: 78%"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>
  </div>
  <section class="container section-gap" id="features">
    <div class="text-center mb-5">
      <span class="psl-mood psl-mood-neutral mb-3 d-inline-flex">What you get</span>
      <h2 class="fw-bold mb-3">A friendly system that helps you understand your day.</h2>
      <p class="text-muted mx-auto" style="max-width: 680px;">
        Built for mood tracking, personal progress, and simple reflections that feel encouraging instead of
        overwhelming.
      </p>
    </div>

    <div class="row g-4 align-items-stretch">
      <div class="col-md-4">
        <div class="psl-card h-100 psl-home-feature-card">
          <img src="https://www.shutterstock.com/image-vector/mood-tracker-blank-hand-drawn-600w-2567370249.jpg"
            alt="A person writing in a notebook" class="psl-home-feature-img">
          <div class="psl-mood psl-mood-creative mb-3">Mood tracking</div>
          <h3 class="h5">Check in with yourself</h3>
          <p class="mb-0">
            Log how you feel in seconds and start seeing patterns across your week.
          </p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="psl-card h-100 psl-home-feature-card">
          <img src="https://www.shutterstock.com/image-illustration/business-growth-concept-ascending-bar-600w-2709113739.jpg"
            alt="Team reviewing progress on a laptop" class="psl-home-feature-img">
          <div class="psl-mood psl-mood-low mb-3">Progress boards</div>
          <h3 class="h5">Watch your growth</h3>
          <p class="mb-0">
            Keep track of habits, goals, and personal wins with a layout that stays easy to use.
          </p>
        </div>
      </div>

      <div class="col-md-4">
        <div class="psl-card h-100 psl-home-feature-card">
          <img src="https://www.shutterstock.com/image-vector/futuristic-technology-concept-smooth-lines-600w-2569751527.jpg"
            alt="Analytics dashboard on a screen" class="psl-home-feature-img">
          <div class="psl-mood psl-mood-creative mb-3">Insight charts</div>
          <h3 class="h5">See your patterns</h3>
          <p class="mb-0">
            Clear charts help you notice what lifts you up, what drains you, and what deserves more attention.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="container section-gap" id="progress">
    <div class="row g-4 align-items-center">
      <div class="col-lg-5">
        <div class="mb-3">
          <span class="psl-mood psl-mood-happy">Weekly progress</span>
        </div>
        <h2 class="fw-bold mb-3">A little dashboard for your real life.</h2>
        <p class="text-muted mb-0">
          Use gentle visuals to understand your habits, focus, and mood over time. No noise, no clutter, just useful
          clarity.
        </p>
      </div>

      <div class="col-lg-7">
        <div class="psl-card p-4 p-md-5">
          <div class="row g-4">
            <div class="col-md-6">
              <h5 class="mb-4">Mood over the last 7 days</h5>

              <div class="psl-home-chart">
                <div class="psl-home-chart-row">
                  <span class="psl-home-chart-label">Mon</span>
                  <div class="psl-home-chart-bar-wrap">
                    <div class="psl-home-chart-bar" style="width: 58%"></div>
                  </div>
                </div>
                <div class="psl-home-chart-row">
                  <span class="psl-home-chart-label">Tue</span>
                  <div class="psl-home-chart-bar-wrap">
                    <div class="psl-home-chart-bar" style="width: 72%"></div>
                  </div>
                </div>
                <div class="psl-home-chart-row">
                  <span class="psl-home-chart-label">Wed</span>
                  <div class="psl-home-chart-bar-wrap">
                    <div class="psl-home-chart-bar" style="width: 46%"></div>
                  </div>
                </div>
                <div class="psl-home-chart-row">
                  <span class="psl-home-chart-label">Thu</span>
                  <div class="psl-home-chart-bar-wrap">
                    <div class="psl-home-chart-bar" style="width: 84%"></div>
                  </div>
                </div>
                <div class="psl-home-chart-row">
                  <span class="psl-home-chart-label">Fri</span>
                  <div class="psl-home-chart-bar-wrap">
                    <div class="psl-home-chart-bar" style="width: 68%"></div>
                  </div>
                </div>
                <div class="psl-home-chart-row">
                  <span class="psl-home-chart-label">Sat</span>
                  <div class="psl-home-chart-bar-wrap">
                    <div class="psl-home-chart-bar" style="width: 90%"></div>
                  </div>
                </div>
                <div class="psl-home-chart-row">
                  <span class="psl-home-chart-label">Sun</span>
                  <div class="psl-home-chart-bar-wrap">
                    <div class="psl-home-chart-bar" style="width: 76%"></div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <h5 class="mb-4">Your progress highlights</h5>

              <div class="psl-home-side-stat mb-3">
                <div class="d-flex justify-content-between mb-2">
                  <span class="text-muted">Focus streak</span>
                  <strong>12 days</strong>
                </div>
                <div class="progress psl-home-progress">
                  <div class="progress-bar" style="width: 82%"></div>
                </div>
              </div>

              <div class="psl-home-side-stat mb-3">
                <div class="d-flex justify-content-between mb-2">
                  <span class="text-muted">Mood balance</span>
                  <strong>76%</strong>
                </div>
                <div class="progress psl-home-progress">
                  <div class="progress-bar" style="width: 76%"></div>
                </div>
              </div>

              <div class="psl-home-side-stat mb-4">
                <div class="d-flex justify-content-between mb-2">
                  <span class="text-muted">Goals completed</span>
                  <strong>5 of 7</strong>
                </div>
                <div class="progress psl-home-progress">
                  <div class="progress-bar" style="width: 71%"></div>
                </div>
              </div>

              <div class="psl-glass-card p-3">
                <div class="d-flex align-items-start gap-3">
                  <div class="psl-mood psl-mood-creative flex-shrink-0">
                    <i class="fas fa-quote-left"></i>
                  </div>
                  <p class="mb-0 text-dark">
                    “You are doing better than you think. PerSysLab keeps the small wins visible.”
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container section-gap" id="community">
    <div class="cta-glass p-4 p-md-5 text-center">
      <span class="psl-mood psl-mood-creative mb-3 d-inline-flex">Ready when you are</span>
      <h2 class="fw-bold mb-3">Start tracking your mood and progress with a little more kindness.</h2>
      <p class="text-muted mb-4 mx-auto" style="max-width: 700px;">
        PerSysLab is built to feel warm, simple, and motivating every time you open it.
      </p>
      <a href="/user/register" class="psl-btn psl-btn-primary psl-btn-lg">Create Your Free Account</a>
    </div>
  </section>

  <footer class="psl-navbar py-4 mt-5">
    <div class="container">
      <div class="row g-4 align-items-center">
        <div class="col-md-4">
          <div class="text-white fw-bold fs-5">PerSysLab</div>
          <small class="text-white-50">Mood tracking and progress, made friendly.</small>
        </div>

        <div class="col-md-4 text-md-center">
          <a href="/privacy" class="text-white-50 text-decoration-none me-3 hover-white">Privacy</a>
          <a href="/terms" class="text-white-50 text-decoration-none me-3 hover-white">Terms</a>
          <a href="/contact" class="text-white-50 text-decoration-none hover-white">Contact</a>
        </div>

        <div class="col-md-4 text-md-end">
          <a href="https://discord.com" target="_blank" rel="noreferrer"
            class="text-white text-decoration-none d-inline-flex align-items-center gap-2 hover-white">
            <i class="fab fa-discord fs-4"></i>
            <span>Join Discord</span>
          </a>
        </div>
      </div>
    </div>
  </footer>

</main>

<script>
  window.addEventListener("scroll", () => {
    document.querySelector(".psl-navbar")
      .classList.toggle("scrolled", window.scrollY > 10);
  });
</script>

